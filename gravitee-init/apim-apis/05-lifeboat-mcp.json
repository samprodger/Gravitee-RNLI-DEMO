        "paths": [
          {
            "path": "/lifeboat-mcp/",
            "overrideAccess": false
          }
        ],
        "pathMappings": [],
        "entrypoints": [
          {
            "type": "http-proxy",
            "qos": "AUTO",
            "configuration": {}
          },
          {
            "type": "mcp",
            "qos": "AUTO",
            "configuration": {
              "mcpPath": "/mcp",
              "tools": [
                {
                  "gatewayMapping": {
                    "http": {
                      "path": "/stations/nearest",
                      "method": "GET",
                      "queryParams": [
                        "location",
                        "count"
                      ]
                    }
                  },
                  "toolDefinition": {
                    "name": "findNearestStations",
                    "description": "Find the nearest RNLI lifeboat stations to a given UK location. The location can be a postcode (e.g. 'SW1A 2AA') or a town name (e.g. 'Brighton'). Returns stations with distances, addresses, and Google Maps walking directions links.",
                    "inputSchema": {
                      "type": "object",
                      "properties": {
                        "location": {
                          "type": "string",
                          "description": "UK postcode or town name to search from, e.g. 'BH15 1HU' or 'Brighton'"
                        },
                        "count": {
                          "type": "integer",
                          "description": "Number of nearest stations to return (default 3, max 10)"
                        }
                      },
                      "required": ["location"]
                    }
                  }
                },
                {
                  "gatewayMapping": {
                    "http": {
                      "path": "/stations",
                      "method": "GET",
                      "queryParams": [
                        "type"
                      ]
                    }
                  },
                  "toolDefinition": {
                    "name": "listStationsByType",
                    "description": "List all RNLI lifeboat stations of a given type. Use 'ALB' for All-weather Lifeboats (large offshore) or 'ILB' for Inshore Lifeboats (smaller, faster, close to shore).",
                    "inputSchema": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "description": "Station type: 'ALB' (all-weather lifeboat) or 'ILB' (inshore lifeboat)",
                          "enum": ["ALB", "ILB"]
                        }
                      },
                      "required": ["type"]
                    }
                  }
                },
                {
                  "gatewayMapping": {
                    "http": {
                      "path": "/stations",
                      "method": "GET",
                      "queryParams": [
                        "region"
                      ]
                    }
                  },
                  "toolDefinition": {
                    "name": "listStationsByRegion",
                    "description": "List all RNLI lifeboat stations in a specific region of the UK or Ireland. Available regions: Scotland, Wales, North East, North West, South East, South West, East, Ireland, Channel Islands.",
                    "inputSchema": {
                      "type": "object",
                      "properties": {
                        "region": {
                          "type": "string",
                          "description": "Region name, e.g. 'Scotland', 'Wales', 'South West', 'Ireland'"
                        }
                      },
                      "required": ["region"]
                    }
                  }
                },
                {
                  "gatewayMapping": {
                    "http": {
                      "path": "/history",
                      "method": "GET"
                    }
                  },
                  "toolDefinition": {
                    "name": "getVisitedStations",
                    "description": "Get the list of RNLI lifeboat stations previously visited by the current user. Returns station names, types, visit dates, addresses, and for Gold Members, recent launch data.",
                    "inputSchema": {
                      "type": "object",
                      "properties": {},
                      "required": []
                    }
                  }
                },
                {
                  "gatewayMapping": {
                    "http": {
                      "path": "/weather/conditions",
                      "method": "GET",
                      "queryParams": ["lat", "lon"]
                    }
                  },
                  "toolDefinition": {
                    "name": "getSeaConditions",
                    "description": "Get current sea conditions for a UK coastal location. Returns wave height, wave period, swell height and direction, wind speed (mph), wind direction, weather description, and visibility. Requires latitude and longitude.",
                    "inputSchema": {
                      "type": "object",
                      "properties": {
                        "lat": {
                          "type": "number",
                          "description": "Latitude of the coastal location (e.g. 50.7161)"
                        },
                        "lon": {
                          "type": "number",
                          "description": "Longitude of the coastal location (e.g. -1.9791)"
                        }
                      },
                      "required": ["lat", "lon"]
                    }
                  }
                },
                {
                  "gatewayMapping": {
                    "http": {
                      "path": "/weather/tides",
                      "method": "GET",
                      "queryParams": ["lat", "lon", "count"]
                    }
                  },
                  "toolDefinition": {
                    "name": "getTidalEvents",
                    "description": "Get the next high and low water tidal events for a UK coastal location. Returns times (UTC) and heights in metres, calculated using harmonic tidal prediction for UK waters.",
                    "inputSchema": {
                      "type": "object",
                      "properties": {
                        "lat": {
                          "type": "number",
                          "description": "Latitude of the coastal location (e.g. 50.7161)"
                        },
                        "lon": {
                          "type": "number",
                          "description": "Longitude of the coastal location (e.g. -1.9791)"
                        },
                        "count": {
                          "type": "integer",
                          "description": "Number of tidal events to return (default 4, max 8)"
                        }
                      },
                      "required": ["lat", "lon"]
                    }
                  }
                }
              ]
            }
          }
        ],
        "servers": []
      }
    ],
