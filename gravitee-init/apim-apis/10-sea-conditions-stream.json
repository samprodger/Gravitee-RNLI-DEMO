{
  "api": {
    "name": "RNLI Sea Conditions Stream",
    "apiVersion": "1.0",
    "definitionVersion": "V4",
    "type": "MESSAGE",
    "description": "Live stream of sea conditions data published by the RNLI Weather Agent after every A2A query. Each event contains wave heights, wind speed, swell, and tidal info for the queried location. Subscribe via SSE to receive events in real time. Topic: rnli.sea-conditions",
    "tags": [],
    "listeners": [
      {
        "type": "HTTP",
        "paths": [{"path": "/sea-conditions-stream/"}],
        "entrypoints": [
          {
            "type": "sse",
            "qos": "AT_MOST_ONCE",
            "configuration": {
              "heartbeatIntervalInMs": 3600000,
              "metadataAsComment": false,
              "headersAsComment": false
            }
          }
        ],
        "cors": {
          "enabled": true,
          "allowOrigin": ["*"],
          "allowMethods": ["GET","OPTIONS"],
          "allowHeaders": ["Content-Type","Authorization","Accept","Origin","Last-Event-ID"],
          "exposeHeaders": [],
          "allowCredentials": false,
          "maxAge": 86400,
          "runPolicies": false
        }
      }
    ],
    "endpointGroups": [
      {
        "name": "redpanda-kafka",
        "type": "kafka",
        "loadBalancer": {"type": "ROUND_ROBIN"},
        "sharedConfiguration": {
          "security": {"protocol": "PLAINTEXT"},
          "consumer": {
            "enabled": true,
            "autoOffsetReset": "latest",
            "encodeMessageId": true,
            "topics": ["rnli.sea-conditions"]
          }
        },
        "endpoints": [
          {
            "name": "redpanda",
            "type": "kafka",
            "weight": 1,
            "inheritConfiguration": true,
            "configuration": {
              "bootstrapServers": "redpanda:9092"
            }
          }
        ]
      }
    ],
    "analytics": {
      "enabled": true,
      "logging": {
        "content": {
          "messageHeaders": true,
          "messagePayload": true,
          "messageMetadata": false
        },
        "phase": {"messageRequest": true, "messageResponse": true},
        "mode": {"endpoint": true, "entrypoint": true}
      }
    },
    "flowExecution": {"mode": "DEFAULT", "matchRequired": false},
    "flows": [],
    "plans": [
      {
        "name": "Free",
        "status": "PUBLISHED",
        "security": {"type": "KEY_LESS"},
        "flows": []
      }
    ]
  }
}
