{
  "api": {
    "name": "LLM Proxy",
    "apiVersion": "1.0",
    "definitionVersion": "V4",
    "type": "PROXY",
    "description": "OpenAI-compatible LLM proxy routing to local Ollama. Used by the RNLI agent for natural-language understanding.",
    "tags": [],
    "listeners": [
      {
        "type": "HTTP",
        "paths": [
          { "path": "/llm-proxy/" }
        ],
        "entrypoints": [
          { "type": "http-proxy" }
        ],
        "cors": {
          "enabled": true,
          "allowOrigin": ["*"],
          "allowMethods": ["GET","POST","PUT","DELETE","OPTIONS","PATCH"],
          "allowHeaders": ["Content-Type","Authorization","Accept","Origin","X-Requested-With"],
          "exposeHeaders": [],
          "allowCredentials": false,
          "maxAge": 86400,
          "runPolicies": false
        }
      }
    ],
    "endpointGroups": [
      {
        "name": "default-group",
        "type": "http-proxy",
        "endpoints": [
          {
            "name": "ollama-local",
            "type": "http-proxy",
            "weight": 1,
            "configuration": {
              "target": "http://host.docker.internal:11434/v1"
            }
          }
        ]
      }
    ],
    "flowExecution": {
      "mode": "DEFAULT",
      "matchRequired": false
    },
    "flows": [],
    "plans": [
      {
        "name": "Free Plan",
        "status": "PUBLISHED",
        "security": { "type": "KEY_LESS" },
        "flows": []
      }
    ]
  }
}
