{
  "api": {
    "name": "LLM Proxy",
    "apiVersion": "1.0",
    "definitionVersion": "V4",
    "type": "PROXY",
    "description": "OpenAI-compatible LLM proxy routing to local Ollama. Used by the RNLI agent for natural-language understanding.",
    "tags": [],
    "listeners": [
      {
        "type": "HTTP",
        "paths": [
          { "path": "/llm-proxy/" }
        ],
        "entrypoints": [
          { "type": "http-proxy" }
        ],
        "cors": {
          "enabled": true,
          "allowOrigin": ["*"],
          "allowMethods": ["GET","POST","PUT","DELETE","OPTIONS","PATCH"],
          "allowHeaders": ["Content-Type","Authorization","Accept","Origin","X-Requested-With"],
          "exposeHeaders": [],
          "allowCredentials": false,
          "maxAge": 86400,
          "runPolicies": false
        }
      }
    ],
    "endpointGroups": [
      {
        "name": "default-group",
        "type": "http-proxy",
        "sharedConfiguration": "{\"proxy\":{\"useSystemProxy\":false,\"enabled\":false},\"http\":{\"keepAliveTimeout\":30000,\"keepAlive\":true,\"propagateClientHost\":false,\"followRedirects\":false,\"readTimeout\":120000,\"idleTimeout\":0,\"connectTimeout\":5000,\"useCompression\":true,\"maxConcurrentConnections\":20,\"version\":\"HTTP_1_1\",\"pipelining\":false},\"ssl\":{\"keyStore\":{\"type\":\"\"},\"hostnameVerifier\":true,\"trustStore\":{\"type\":\"\"},\"trustAll\":false}}",
        "endpoints": [
          {
            "name": "ollama-local",
            "type": "http-proxy",
            "weight": 1,
            "configuration": {
              "target": "http://host.docker.internal:11434/v1"
            }
          }
        ]
      }
    ],
    "analytics": {
      "enabled": true,
      "logging": {
        "content": {
          "headers": true,
          "messageHeaders": false,
          "payload": true,
          "messagePayload": false,
          "messageMetadata": false
        },
        "phase": { "request": true, "response": true },
        "mode": { "endpoint": true, "entrypoint": true }
      },
      "tracing": { "enabled": false, "verbose": false }
    },
    "flowExecution": {
      "mode": "DEFAULT",
      "matchRequired": false
    },
    "flows": [],
    "plans": [
      {
        "name": "Free Plan",
        "status": "PUBLISHED",
        "security": { "type": "KEY_LESS" },
        "flows": []
      }
    ]
  }
}
